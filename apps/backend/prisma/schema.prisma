datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum TrainingType {
  Trained
  CascadeTrained
  TrainingConfirmed
}

enum Species {
  Cattle
  Sheep
  Goat
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  status    String
  checkedAt DateTime @default(now())
}

model Site {
  plant_no          String   @id @db.VarChar(11)
  name              String   @unique @db.VarChar(50)
  address_line_1    String?  @db.VarChar(50)
  address_line_2    String?  @db.VarChar(50)
  address_town      String?  @db.VarChar(50)
  address_county    String?  @db.VarChar(50)
  address_post_code String?  @db.VarChar(50)
  telephone         String?  @db.VarChar(50)
  fax               String?  @db.VarChar(50)
  is_apha_site      Boolean  @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  persons  Person[]  @relation("SitePersons")
  trainers Trainer[] @relation("SiteTrainers")

  @@index([name])
  @@map("sites")
}

model Person {
  person_id    Int      @id @default(autoincrement())
  first_name   String   @db.VarChar(50)
  last_name    String   @db.VarChar(50)
  display_name String   @db.VarChar(101)
  site_id      String   @db.VarChar(11)
  has_training Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  site      Site       @relation("SitePersons", fields: [site_id], references: [plant_no])
  trainer   Trainer?   @relation("PersonTrainer")
  trainings Training[] @relation("TraineeTrainings")

  @@index([first_name, last_name, site_id])
  @@map("persons")
}

model Trainer {
  trainer_id   Int      @id @default(autoincrement())
  first_name   String   @db.VarChar(50)
  last_name    String   @db.VarChar(50)
  display_name String   @db.VarChar(101)
  location_id  String   @db.VarChar(11)
  person_id    Int?     @unique
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  location  Site       @relation("SiteTrainers", fields: [location_id], references: [plant_no])
  person    Person?    @relation("PersonTrainer", fields: [person_id], references: [person_id])
  trainings Training[] @relation("TrainerTrainings")

  @@map("trainers")
}

model Training {
  training_id    Int          @id @default(autoincrement())
  trainee_id     Int
  trainer_id     Int
  date_trained   DateTime     @db.Date
  species_trained Species[]
  training_type  TrainingType
  is_deleted     Boolean      @default(false)
  created_by     String?      @default("system")
  created_at     DateTime     @default(now())
  modified_by    String?      @default("system")
  modified_at    DateTime     @updatedAt
  deleted_by     String?
  deleted_at     DateTime?

  trainee Person  @relation("TraineeTrainings", fields: [trainee_id], references: [person_id], onDelete: Restrict)
  trainer Trainer @relation("TrainerTrainings", fields: [trainer_id], references: [trainer_id], onDelete: Restrict)

  @@index([trainee_id])
  @@index([trainer_id])
  @@index([date_trained])
  @@map("trainings")
}
