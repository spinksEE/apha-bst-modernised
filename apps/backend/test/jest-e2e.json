{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "tsconfig": "<rootDir>/tsconfig.e2e.json"
    }]
  },
  "moduleNameMapper": {
    "^@apha-bst/shared(.*)$": "<rootDir>/../../packages/shared/src$1"
  }
}
